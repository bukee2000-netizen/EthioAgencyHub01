# Telegram Bot Configuration (for document storage)
# ================================================

# Telegram Bot Token (get from @BotFather on Telegram)
# 1. Open Telegram and search for @BotFather
# 2. Use /newbot command to create a new bot
# 3. Copy the HTTP API token provided
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Private Channel ID
# To get your channel ID:
# 1. Add your bot to the channel as an admin
# 2. Forward a message from the channel to @channelidbot
# 3. Or use @RawDataBot to get the channel ID
# Channel ID format: -1001234567890 (starts with -100)
TG_CHANNEL_ID=-1001234567890


# WhatsApp Business Configuration (for notifications)
# ===================================================

# WhatsApp Phone Number ID (from Meta Developer Portal)
# 1. Go to https://developers.facebook.com/
# 2. Create an app and add WhatsApp product
# 3. Copy the Phone Number ID
WHATSAPP_PHONE_ID=your_whatsapp_phone_id

# WhatsApp Access Token
# Get from: Meta Developer Portal > WhatsApp > Configuration
# Note: This token expires, you may need to refresh it periodically
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# WhatsApp Verify Token (for webhook verification)
# Set this to any random string you'll use to verify your webhook
WHATSAPP_VERIFY_TOKEN=your_verify_token_here


# Alternative: If using Twilio for WhatsApp
# ==========================================
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=+14155238886