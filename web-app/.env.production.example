# ========================================
# EthioAgencyHub - Production Environment
# ========================================

# App Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Database (PostgreSQL — used in production / Docker)
# For Docker Compose, this is auto-configured. For standalone deploys, set manually.
DATABASE_URL=postgresql://user:password@host:5432/ethio_agency_hub

# Authentication
JWT_SECRET=generate-a-very-long-secure-random-string-at-least-32-chars

# Telegram Bot (for video uploads — leave empty to disable)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TG_CHANNEL_ID=-100xxxxxxxxxx

# File Storage
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE_MB=50
MAX_FILE_SIZE=52428800

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# ========================================
# Docker Compose specific (used by docker-compose.yml)
# ========================================
# These are consumed by docker-compose.yml, not the app directly.
# Override by creating a .env file in the project root.

# PostgreSQL root password
# POSTGRES_ROOT_PASSWORD=root_password

# PostgreSQL application user password
# POSTGRES_PASSWORD=agency_password

# App port mapping
# APP_PORT=3000

# Seed demo data on first run (set to "true")
# SEED_DB=false